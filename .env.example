# Copy to .env and adjust. Docker Compose loads .env automatically for ${VAR} in docker-compose.yml.
# Secrets: never commit .env (gitignored).

# Build metadata (optional; Makefile often sets these)
# VERSION=dev
# GIT_COMMIT=none

# Kube in Docker (podnoir service, playtest-smoke-ci)
# POD_NOIR_KUBE_IN_DOCKER=true
# POD_NOIR_KUBE_API_HOST=
# POD_NOIR_KUBE_TLS_INSECURE=

# Events
# POD_NOIR_EVENTS_ADAPTER=stdout
# POD_NOIR_NATS_URL=
# POD_NOIR_NATS_SUBJECT_PREFIX=pod-noir
# POD_NOIR_NATS_BRIDGE=false
# POD_NOIR_NATS_BRIDGE_EVENTS_PREFIX=events.pod_noir

# LLM (passed into container when using compose run podnoir)
# POD_NOIR_LLM_PROVIDER=mock
# POD_NOIR_LLM_API_KEY=
# POD_NOIR_LLM_MODEL=
# POD_NOIR_LLM_BASE_URL=
# POD_NOIR_LLM_FALLBACK_MOCK=true
# POD_NOIR_LLM_REPAIR=true
# POD_NOIR_LLM_CONTACT_WIRE=true
